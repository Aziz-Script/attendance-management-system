<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorAppBackground"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="36dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/circle_btn"
            android:padding="10dp"
            android:contentDescription="Back"
            app:tint="#CCFFFFFF"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Profile card ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/statChipDrawable"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/profile_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="U"
            android:textColor="#2E4F3D"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/avatar_circle"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/profile_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Preferences label ────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_preferences"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp"/>

    <!-- ── Preferences card ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/statChipDrawable"
        android:layout_marginBottom="16dp">

        <!-- Notifications row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_popup_reminder"
                android:layout_marginEnd="14dp"
                app:tint="#80FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/notifications"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/notifications_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FFFFFF"
                android:trackTint="#2E4F3D"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#15FFFFFF"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Theme row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_marginEnd="14dp"
                app:tint="#80FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="?attr/statChipDrawable"
                android:padding="3dp">

                <Button
                    android:id="@+id/btn_theme_green"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:text="@string/theme_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/language_unselected"
                    app:backgroundTint="@null"
                    android:foreground="@null"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"/>

                <Button
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:text="@string/theme_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/language_unselected"
                    app:backgroundTint="@null"
                    android:foreground="@null"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#15FFFFFF"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Language row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_compass"
                android:layout_marginEnd="14dp"
                app:tint="#80FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="?attr/statChipDrawable"
                android:padding="3dp">

                <Button
                    android:id="@+id/btn_english"
                    android:layout_width="44dp"
                    android:layout_height="32dp"
                    android:text="EN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/language_unselected"
                    app:backgroundTint="@null"
                    android:foreground="@null"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"/>

                <Button
                    android:id="@+id/btn_arabic"
                    android:layout_width="44dp"
                    android:layout_height="32dp"
                    android:text="AR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/language_unselected"
                    app:backgroundTint="@null"
                    android:foreground="@null"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ── General label ────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_general"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp"/>

    <!-- ── General card ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/statChipDrawable"
        android:layout_marginBottom="16dp">

        <!-- About row -->
        <LinearLayout
            android:id="@+id/about_app"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:layout_marginEnd="14dp"
                app:tint="#80FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/about_app"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="#60FFFFFF"
                android:textSize="20sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Spacer ────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Logout button — standalone at bottom ─────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/log_out"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="#bf0000"
        app:cornerRadius="14dp"
        app:rippleColor="#40FFFFFF"
        android:layout_marginBottom="32dp"/>

</LinearLayout>