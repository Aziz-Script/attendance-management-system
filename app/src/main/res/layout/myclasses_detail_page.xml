<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorAppBackground"
    android:padding="16dp">

    <!-- Back Arrow -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Course Code -->
    <TextView
        android:id="@+id/courseCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COCS110"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White Card -->
    <LinearLayout
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_white_card"
        android:padding="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/courseCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Building -->
        <TextView
            android:id="@+id/building"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2E4F3D"
            android:text="Building:"
            android:textSize="16sp"
            android:paddingBottom="12dp" />

        <!-- Room -->
        <TextView
            android:id="@+id/room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2E4F3D"
            android:text="Room:"
            android:textSize="16sp"
            android:paddingBottom="12dp" />

    </LinearLayout>

    <!-- Take Attendance Button -->
    <Button
        android:id="@+id/takeAttendanceBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_take_attendance"
        android:backgroundTint="@color/white"
        android:textColor="#2E4F3D"
        android:padding="12dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/infoCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Attendance History Button -->
    <Button
        android:id="@+id/attendanceHistoryBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_attendance_history"
        android:backgroundTint="@color/white"
        android:textColor="#2E4F3D"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/takeAttendanceBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Student List Button -->


</androidx.constraintlayout.widget.ConstraintLayout>
