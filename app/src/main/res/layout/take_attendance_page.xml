<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorAppBackground"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/circle_btn"
            android:padding="10dp"
            android:contentDescription="Back"
            app:tint="#CCFFFFFF"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_take_attendance"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subtitle_share_code"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── ATTENDANCE CODE label ──────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_attendance_code"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp"/>

    <!-- ── Code display ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/statChipDrawable">

        <TextView
            android:id="@+id/generatedCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- - - - -"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            android:textColor="#60FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- ── SESSION TIMER label ────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_session_timer"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"/>

    <!-- ── Timer display ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/statChipDrawable">

        <TextView
            android:id="@+id/timerDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_no_timer"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Slide to cancel — hidden until session active ─────── -->
    <com.example.aws.SlideToCancelView
        android:id="@+id/slideToCancelView"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:visibility="gone"/>

    <!-- ── Flex spacer ────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Action buttons ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseTimer"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_choose_duration"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#60FFFFFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="14dp"
            android:layout_marginEnd="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerateCode"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_generate_code"
            android:textColor="#2E4F3D"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="14dp"
            app:rippleColor="#402E4F3D"/>
    </LinearLayout>

</LinearLayout>