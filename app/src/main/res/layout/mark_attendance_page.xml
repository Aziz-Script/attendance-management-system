<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorAppBackground"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/circle_btn"
            android:padding="10dp"
            android:contentDescription="Back"
            app:tint="#CCFFFFFF"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_mark_attendance"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/courseCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Flex spacer ────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── ENTER CODE label ───────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_enter_code"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp"/>

    <!-- ── Code input card ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/statChipDrawable"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <EditText
            android:id="@+id/codeInput"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:inputType="number"
            android:maxLength="5"
            android:hint="· · · · ·"
            android:textColorHint="#60FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.3"
            android:background="@null"
            android:padding="0dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#40FFFFFF"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/submitBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_submit_attendance"
            android:textColor="#2E4F3D"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="14dp"
            app:rippleColor="#402E4F3D"/>
    </LinearLayout>

    <!-- ── Flex spacer ────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="32dp"/>

</LinearLayout>
